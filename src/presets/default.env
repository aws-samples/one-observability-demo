# Default preset - Standard configuration with most features enabled
# This preset provides a balanced setup suitable for general use

# ============================================================================
# Infrastructure Configuration
# ============================================================================

# Create a new VPC (set to false to use existing VPC specified by VPC_ID)
CREATE_VPC=true

# VPC CIDR range (only used if CREATE_VPC=true)
VPC_CIDR=10.0.0.0/16

# Existing VPC ID to use (only used if CREATE_VPC=false)
# VPC_ID=vpc-xxxxxxxxx

# Create CloudTrail for API activity logging
CREATE_CLOUDTRAIL=true

# Availability Zones to use (comma-separated, leave empty for automatic selection)
# AVAILABILITY_ZONES=us-east-1a,us-east-1b

# ============================================================================
# Workshop Customization Options
# ============================================================================

# Enable export page functionality
CUSTOM_ENABLE_EXPORT_PAGE=false

# Enable AWS WAF for CloudFront distribution
CUSTOM_ENABLE_WAF=false

# Enable CloudFront access logs
CUSTOM_ENABLE_CLOUDFRONT_LOGS=false

# Enable GuardDuty EKS addon for runtime threat detection
CUSTOM_ENABLE_GUARDDUTY_EKS_ADDON=false

# Enable CloudTrail for networking events
CUSTOM_ENABLE_NETWORKING_TRAIL=false

# IAM role name for EKS cluster access (leave empty for default)
EKS_CLUSTER_ACCESS_ROLE_NAME=

# Enable Service Level Objectives (SLO) monitoring
CUSTOM_ENABLE_SLO=false

# ============================================================================
# Application Features
# ============================================================================

# Enable Pet Food Agent (Bedrock-based AI agent)
ENABLE_PET_FOOD_AGENT=true

# Enable OpenSearch components (collection, pipeline, and application)
ENABLE_OPENSEARCH=true

# ============================================================================
# Account-Specific Configuration
# ============================================================================

# Auto-configure transaction search (set by deployment scripts)
AUTO_TRANSACTION_SEARCH_CONFIGURED=false

# Maximum number of concurrent users for traffic generator (0 to disable)
CONCURRENT_USERS=5